---
import MainLayout from "../layouts/MainLayout.astro";
import IconButton from "../components/IconButton.astro";
---

<MainLayout title="DURSIA - Demo">
  <main class="flex justify-center items-center h-screen relative">
    <IconButton href="/">
      <img src="/assets/icons/arrow-back.svg" alt="back-arrow" class="w-14 h-14 absolute z-10 bottom-0 m-2 p-2 right-0" />
    </IconButton>
    <video autoplay controls class="max-h-[92vh]"><source type="video/mp4" src="../assets/video/dursia-demo-82mb.mp4" /></video>
  </main>
</MainLayout>
